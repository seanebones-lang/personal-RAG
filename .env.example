# PersonalRAGVault configuration (copy to .env and adjust)

# ChromaDB storage path
PRV_DB_PATH=~/.personalragvault/chroma

# Embedding: preset (mini | bge-small | bge-base) or explicit model id
PRV_EMBED_PRESET=mini
# PRV_EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Ollama
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2

# Ingest limits
PRV_MAX_FILE_BYTES=52428800
PRV_CHUNK_STRATEGY=char
PRV_CHUNK_SIZE=800
PRV_CHUNK_OVERLAP=120
PRV_CHUNK_MIN_SIZE=200
PRV_CHUNK_MAX_SIZE=800
PRV_MAX_CONTEXT_CHARS=12000

# Query defaults
PRV_MAX_TOP_K=50
PRV_EMBED_BATCH_SIZE=32
PRV_USE_FILE_CACHE=true
PRV_USE_FTS=true
PRV_USE_EMBEDDING_CACHE=true
PRV_HYBRID_FETCH_LIMIT=5000
PRV_HYBRID_RRF_K=60
PRV_HNSW_SEARCH_EF=100
PRV_HNSW_M=16
