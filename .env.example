# PersonalRAGVault configuration (copy to .env and adjust)

# ChromaDB storage path
PRV_DB_PATH=~/.personalragvault/chroma

# Embedding model (Hugging Face id or sentence-transformers name)
PRV_EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Ollama
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2

# Ingest limits
PRV_MAX_FILE_BYTES=52428800
PRV_CHUNK_SIZE=800
PRV_CHUNK_OVERLAP=120
PRV_MAX_CONTEXT_CHARS=12000

# Query defaults
PRV_MAX_TOP_K=50
